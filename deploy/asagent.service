# systemd unit for asagent (durable single-process deploy on :8899).
# Install (passwordless sudo or run manually):
#   sudo cp deploy/asagent.service /etc/systemd/system/asagent.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now asagent
# Logs: journalctl -u asagent -f
[Unit]
Description=asagent — agent platform (FastAPI + LangGraph)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/dev/asagent/backend
EnvironmentFile=/home/ubuntu/dev/asagent/backend/.env
ExecStart=/home/ubuntu/miniconda3/envs/as/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8899
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
