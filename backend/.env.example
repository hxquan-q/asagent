# ===== App =====
APP_NAME=asagent
DEBUG=true

# ===== Metadata DB (platform's own Postgres) =====
# example: postgresql+psycopg://asagent:asagent@localhost:5432/asagent
DATABASE_URL=postgresql+psycopg://asagent:asagent@localhost:5432/asagent
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ===== Secrets =====
# Used to encrypt LLM api keys / datasource passwords at rest (Fernet).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=change-me-generate-a-fernet-key
# JWT signing
JWT_SECRET=change-me-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== Auth / bootstrap admin =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===== API Key =====
API_KEY_PREFIX=ask

# ===== Storage =====
SKILLS_DIR=./data/skills
FILES_DIR=./data/files

# ===== Sandbox =====
# default | docker  (default uses langchain-sandbox / Pyodide)
SANDBOX_BACKEND=pyodide
SANDBOX_DOCKER_IMAGE=asagent-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
